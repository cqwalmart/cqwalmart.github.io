  "questions": [
    {"id":1,"weight":1.0,"text":"你最近最常卡住你的，更像是哪一种：","options":{"A":[1.2,0,0.7,0,1.5,0,0,0,0.3,0,0,0],"B":[0,1.5,0,1.1,0,0.4,0,0,0,1.4,0,0],"C":[0,0,0,0,1.5,0,0.3,0,0.6,0,1.2,0],"D":[0,0,1.5,0,0,0,0,0.4,1.1,0,0,1.4]}},
    {"id":2,"weight":1.0,"text":"如果这次考试考砸了，你第一反应更像：","options":{"A":[0,0,0,0,1.4,0,0.3,0,1.0,0,1.2,0],"B":[0.2,0,1.1,0.9,0,0,0,0,0,1.2,0,0],"C":[0,0,0,0,1.0,0,0.8,1.1,0.6,0.8,0.8,0],"D":[0,0,0,0.3,0.8,0,0.8,0,1.1,0.5,1.0,0]}},
    {"id":3,"weight":1.0,"text":"如果老师说“这部分最能拉开差距”，你更容易：","options":{"A":[0.2,1.4,0,1.2,0,0,0,0,0,1.1,0,0],"B":[0,0,0,1.0,0,0.4,0,1.3,0,1.2,0,0],"C":[0,0.3,0,0,0,1.3,0.8,1.1,0,0,0,0],"D":[0.2,0,1.0,0,1.2,0,0,0,0.4,0,0,0]}},
