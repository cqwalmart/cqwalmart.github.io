    {"id":5,"weight":1.0,"text":"你什么时候会最明显觉得，之前那样学没白费：","options":{"A":[1.6,0,0.3,0,0.4,0,1.0,0.8,0.2,0,0,0],"B":[0.1,1.5,0.4,1.3,0,0,0,0,0.4,1.4,0,0],"C":[0.3,0,1.3,0,1.1,0,0,0,0.4,0,0.2,0],"D":[0,1.4,0.5,0,0,1.2,0,1.0,0.2,0,0,0.4]}},
